        "def build_price_summary(prices):\n",
        "    return pd.DataFrame({\n",
        "        \"Ticker\":       prices.columns,\n",
        "        \"First Price\":  prices.iloc[0].values,\n",
        "        \"Last Price\":   prices.iloc[-1].values,\n",
        "        \"Total Return\": prices.iloc[-1].values / prices.iloc[0].values - 1\n",
        "    }).round(4)\n",
        "\n",
        "\n",
        "def build_risk_return_summary(prices):\n",
        "    returns = prices.pct_change().dropna()\n",
        "    return pd.DataFrame({\n",
        "        \"Ticker\":               returns.columns,\n",
        "        \"Mean Daily Return\":    returns.mean().values,\n",
        "        \"Daily Volatility\":     returns.std().values,\n",
        "        \"Annualized Return\":    (returns.mean() * TRADING_DAYS).values,\n",
        "        \"Annualized Volatility\":(returns.std() * np.sqrt(TRADING_DAYS)).values\n",
        "    }).round(4)\n",
        "\n",
        "\n",
        "def evaluate_portfolio(returns_series, name, weights_df, periods_per_year, rf_annual):\n",
        "    cumulative = (1 + returns_series).cumprod()\n",
        "    return {\n",
        "        \"Portfolio\":         name,\n",
        "        \"Annual Return\":     annualize_return(returns_series, periods_per_year),\n",
        "        \"Annual Volatility\": annualize_volatility(returns_series, periods_per_year),\n",
        "        \"Sharpe Ratio\":      sharpe_ratio(returns_series, rf_annual, periods_per_year),\n",
        "        \"Max Drawdown\":      max_drawdown(cumulative),\n",
        "        \"Cumulative Return\": cumulative.iloc[-1] - 1,\n",
        "        \"Average Turnover\":  turnover_from_weights(weights_df)\n",
        "    }"
      ]
    },
