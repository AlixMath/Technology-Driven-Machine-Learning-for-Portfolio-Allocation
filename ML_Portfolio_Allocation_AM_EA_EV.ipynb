        "---\n",
        "2. DOWNLOAD AND CLEAN DATA\n",
        "---\n",
        "Pipeline de nettoyage :\n",
        "  1. Téléchargement des prix ajustés via yfinance\n",
        "  2. Filtrage des tickers avec trop de NaN (< 90% présence)\n",
        "  3. Filtrage des dates avec trop de NaN (> 10% actifs manquants)\n",
        "  4. Forward-fill puis backward-fill résiduel\n",
        "  5. Validation : >= 300 observations requises\n",
        "\n",
        "Résultat attendu : 42 actifs × 1 806 jours ouvrables\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "evxy4gTVA5GP"
      },
      "outputs": [],
      "source": [
        "def download_and_clean_prices(\n",
        "    tickers,\n",
        "    start,\n",
        "    end,\n",
        "    min_non_na_ratio=0.90,\n",
        "    max_missing_ratio_per_row=0.10\n",
        "):\n",
        "    data = yf.download(\n",
        "        tickers,\n",
        "        start=start,\n",
        "        end=end,\n",
        "        auto_adjust=True,\n",
        "        progress=False\n",
        "    )\n",
        "\n",
        "    if isinstance(data.columns, pd.MultiIndex):\n",
        "        if \"Close\" in data.columns.get_level_values(0):\n",
        "            prices = data[\"Close\"].copy()\n",
        "        else:\n",
        "            raise ValueError(\"Yahoo Finance did not return Close prices.\")\n",
        "    else:\n",
        "        prices = data.copy()\n",
        "\n",
        "    if prices.empty:\n",
        "        raise ValueError(\"No price data downloaded.\")\n",
        "\n",
        "    available_tickers = [t for t in tickers if t in prices.columns]\n",
        "    prices = prices[available_tickers]\n",
        "\n",
        "    prices = prices[~prices.index.duplicated(keep=\"first\")].sort_index()\n",
        "\n",
        "    min_non_na_count = int(len(prices) * min_non_na_ratio)\n",
        "    prices = prices.dropna(axis=1, thresh=min_non_na_count)\n",
        "\n",
        "    if prices.shape[1] == 0:\n",
        "        raise ValueError(\"All tickers removed after missing-value filtering.\")\n",
        "\n",
        "    min_non_na_row_count = int(prices.shape[1] * (1 - max_missing_ratio_per_row))\n",
        "    prices = prices.dropna(axis=0, thresh=min_non_na_row_count)\n",
        "\n",
        "    prices = prices.ffill().bfill().dropna(how=\"any\")\n",
        "\n",
        "    if prices.empty:\n",
        "        raise ValueError(\"Prices empty after cleaning.\")\n",
        "\n",
        "    if len(prices) < 300:\n",
        "        raise ValueError(\"Too few observations after cleaning.\")\n",
        "\n",
        "    return prices"
      ]
    },
