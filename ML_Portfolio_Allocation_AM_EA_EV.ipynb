      "source": [
        "prices = download_and_clean_prices(\n",
        "    tickers=TICKERS,\n",
        "    start=START_DATE,\n",
        "    end=END_DATE,\n",
        "    min_non_na_ratio=MIN_NON_NA_RATIO_PER_TICKER,\n",
        "    max_missing_ratio_per_row=MAX_MISSING_RATIO_PER_ROW\n",
        ")\n",
        "\n",
        "TICKERS = list(prices.columns)\n",
        "print(\"Number of usable tickers:\", len(TICKERS))\n",
        "print(\"Usable tickers:\", TICKERS)\n",
        "\n",
        "# --- 11.2 Statistiques descriptives ---\n",
        "df_price_summary       = build_price_summary(prices)\n",
        "df_risk_return_summary = build_risk_return_summary(prices)\n",
        "df_correlation_matrix  = prices.pct_change().dropna().corr().round(4)\n",
        "\n",
        "# --- 11.3 Feature engineering et split ---\n",
        "X, y = prepare_dataset(prices, horizon_days=HORIZON_DAYS)\n",
        "print(\"X shape:\", X.shape)\n",
        "print(\"y shape:\", y.shape)\n",
        "\n",
        "X_train, X_test, y_train, y_test = time_series_train_test_split(X, y, train_end_date=TRAIN_END_DATE)\n",
        "\n",
        "# --- 11.4 Entraînement des modèles ---\n",
        "print(\"Training Linear Regression...\")\n",
        "linear_predictions, linear_metrics = fit_predict_per_asset_fast(\n",
        "    X_train, X_test, y_train, y_test, model_type=\"linear\"\n",
        ")\n",
        "\n",
        "print(\"Training Random Forest...\")\n",
        "rf_predictions, rf_metrics = fit_predict_per_asset_fast(\n",
        "    X_train, X_test, y_train, y_test, model_type=\"rf\"\n",
        ")\n",
        "\n",
        "# --- 11.5 Métriques prédictives ---\n",
        "# Résultats par actif\n",
        "df_model_metrics = pd.concat([linear_metrics, rf_metrics], ignore_index=True).round(4)\n",
        "\n",
        "# Résultats agrégés (moyenne sur tous les actifs)\n",
        "df_model_metrics_summary = (\n",
        "    df_model_metrics\n",
        "    .groupby(\"Model\")[[\"RMSE\", \"MAE\", \"R2\", \"Directional Accuracy\"]]\n",
        "    .mean()\n",
        "    .round(4)\n",
        "    .reset_index()\n",
        ")\n",
        "print(\"\\nModel metrics summary (averaged across all assets):\")\n",
        "print(df_model_metrics_summary.to_string(index=False))\n",
        "print(\"\\nNote : R² < 0 est universel (marchés quasi-efficients).\")\n",
        "print(\"       Directional Accuracy attendue : LR ~51.9%, RF ~53.0%\")\n",
        "\n",
        "# --- 11.6 Alignement temporel ---\n",
        "realized_returns = prices.pct_change(HORIZON_DAYS).shift(-HORIZON_DAYS).loc[X_test.index]\n",
        "realized_returns = realized_returns[rf_predictions.columns]\n",
        "\n",
        "common_index = (\n",
        "    realized_returns.dropna().index\n",
        "    .intersection(rf_predictions.index)\n",
        "    .intersection(linear_predictions.index)\n",
        ")\n",
        "\n",
        "realized_returns   = realized_returns.loc[common_index]\n",
        "rf_predictions     = rf_predictions.loc[common_index]\n",
        "linear_predictions = linear_predictions.loc[common_index]\n",
        "X_backtest         = X.loc[common_index]\n",
        "\n",
        "if realized_returns.empty:\n",
