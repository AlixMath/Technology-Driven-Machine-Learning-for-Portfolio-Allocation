      "source": [
        "---\n",
        "3. FEATURE ENGINEERING\n",
        "---\n",
        "15 features idiosyncratiques par actif + 6 variables marché.\n",
        "\n",
        "Features par actif :\n",
        "  Momentum  : ret_1, ret_5, ret_20\n",
        "  Volatilité: vol_5, vol_20\n",
        "  Tendance  : ma_ratio_10_20, ma_ratio_20_50, price_to_ma20\n",
        "  Technique : rsi_14\n",
        "\n",
        "Variables marché (partagées) :\n",
        "  market_ret_1/5, market_vol_20\n",
        "  bond_proxy_ret_5, gold_proxy_ret_5, tech_proxy_ret_5\n",
        "\n",
        "Anti-lookahead : toutes les features décalées de shift(1).\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "C4ibLqyDA5GP"
      },
      "outputs": [],
      "source": [
        "def compute_rsi(series, window=14):\n",
        "    delta = series.diff()\n",
        "    gain  = delta.clip(lower=0).rolling(window=window).mean()\n",
        "    loss  = (-delta.clip(upper=0)).rolling(window=window).mean()\n",
        "    rs    = gain / loss.replace(0, np.nan)\n",
        "    return 100 - (100 / (1 + rs))\n",
        "\n",
        "\n",
        "def safe_group_mean(df, candidates):\n",
        "    cols = [c for c in candidates if c in df.columns]\n",
        "    if len(cols) == 0:\n",
        "        return pd.Series(0.0, index=df.index)\n",
        "    return df[cols].mean(axis=1)\n",
        "\n",
        "\n",
        "def build_features(prices):\n",
        "    returns = prices.pct_change()\n",
        "    feature_blocks = []\n",
        "\n",
        "    market_return = returns.mean(axis=1)\n",
        "    market_vol_20 = market_return.rolling(20).std()\n",
        "\n",
        "    bond_proxy = safe_group_mean(returns, [\"TLT\", \"IEF\", \"SHY\", \"LQD\"])\n",
        "    gold_proxy = safe_group_mean(returns, [\"GLD\"])\n",
        "    tech_proxy = safe_group_mean(returns, [\"AAPL\", \"MSFT\", \"NVDA\", \"META\", \"AMZN\"])\n",
        "\n",
        "    for ticker in prices.columns:\n",
        "        px = prices[ticker]\n",
        "        r  = returns[ticker]\n",
        "\n",
        "        df = pd.DataFrame(index=prices.index)\n",
        "\n",
        "        # Momentum / lagged returns\n",
        "        df[f\"{ticker}_ret_1\"]  = r.shift(1)\n",
        "        df[f\"{ticker}_ret_5\"]  = px.pct_change(5).shift(1)\n",
        "        df[f\"{ticker}_ret_20\"] = px.pct_change(20).shift(1)\n",
        "\n",
        "        # Volatility\n",
        "        df[f\"{ticker}_vol_5\"]  = r.rolling(5).std().shift(1)\n",
        "        df[f\"{ticker}_vol_20\"] = r.rolling(20).std().shift(1)\n",
        "\n",
        "        # Trend\n",
        "        ma_10 = px.rolling(10).mean()\n",
        "        ma_20 = px.rolling(20).mean()\n",
        "        ma_50 = px.rolling(50).mean()\n",
        "\n",
        "        df[f\"{ticker}_ma_ratio_10_20\"] = (ma_10 / ma_20 - 1).shift(1)\n",
        "        df[f\"{ticker}_ma_ratio_20_50\"] = (ma_20 / ma_50 - 1).shift(1)\n",
        "        df[f\"{ticker}_price_to_ma20\"]  = (px / ma_20 - 1).shift(1)\n",
        "\n",
        "        # RSI\n",
        "        df[f\"{ticker}_rsi_14\"] = compute_rsi(px, 14).shift(1)\n",
        "\n",
        "        feature_blocks.append(df)\n",
        "\n",
        "    features = pd.concat(feature_blocks, axis=1)\n",
        "\n",
        "    # Market context\n",
        "    features[\"market_ret_1\"]     = market_return.shift(1)\n",
        "    features[\"market_ret_5\"]     = market_return.rolling(5).mean().shift(1)\n",
        "    features[\"market_vol_20\"]    = market_vol_20.shift(1)\n",
        "    features[\"bond_proxy_ret_5\"] = bond_proxy.rolling(5).mean().shift(1)\n",
        "    features[\"gold_proxy_ret_5\"] = gold_proxy.rolling(5).mean().shift(1)\n",
        "    features[\"tech_proxy_ret_5\"] = tech_proxy.rolling(5).mean().shift(1)\n",
        "\n",
        "    features = features.replace([np.inf, -np.inf], np.nan)\n",
        "    return features\n",
        "\n",
        "\n",
        "def build_targets(prices, horizon_days=5):\n",
        "    target = prices.pct_change(horizon_days).shift(-horizon_days)\n",
        "    target.columns = [f\"{c}_target\" for c in target.columns]\n",
        "    return target\n",
        "\n",
        "\n",
        "def prepare_dataset(prices, horizon_days=5):\n",
        "    X = build_features(prices)\n",
        "    y = build_targets(prices, horizon_days=horizon_days)\n",
        "\n",
        "    data = pd.concat([X, y], axis=1)\n",
        "    data = data.dropna(axis=1, how=\"all\")\n",
        "    data = data.replace([np.inf, -np.inf], np.nan)\n",
        "\n",
        "    feature_cols = X.columns.intersection(data.columns)\n",
        "    target_cols  = y.columns.intersection(data.columns)\n",
        "\n",
        "    # Imputation features : ffill puis médiane — préserve les lignes\n",
        "    data[feature_cols] = data[feature_cols].ffill().bfill()\n",
        "    for col in feature_cols:\n",
        "        if data[col].isna().any():\n",
        "            data[col] = data[col].fillna(data[col].median())\n",
        "\n",
        "    # Supprime uniquement les lignes où TOUTES les targets sont NaN\n",
        "    data = data.dropna(subset=target_cols, how=\"all\")\n",
        "\n",
        "    if data.empty:\n",
        "        raise ValueError(\"Dataset empty after feature engineering.\")\n",
        "\n",
        "    X_final = data[feature_cols]\n",
        "    y_final = data[target_cols]\n",
        "\n",
        "    return X_final, y_final\n",
        "\n",
        "\n",
        "def time_series_train_test_split(X, y, train_end_date):\n",
        "    # Split chronologique strict par date (pas de mélange aléatoire)\n",
        "    split_idx = X.index.searchsorted(pd.Timestamp(train_end_date))\n",
        "\n",
        "    X_train = X.iloc[:split_idx].copy()\n",
        "    X_test  = X.iloc[split_idx:].copy()\n",
        "    y_train = y.iloc[:split_idx].copy()\n",
        "    y_test  = y.iloc[split_idx:].copy()\n",
        "\n",
        "    if X_train.empty or X_test.empty or y_train.empty or y_test.empty:\n",
        "        raise ValueError(\"Train/test split produced empty data.\")\n",
        "\n",
        "    print(f\"[SPLIT] Train : {X_train.index[0].date()} → {X_train.index[-1].date()} ({len(X_train)} dates)\")\n",
        "    print(f\"[SPLIT] Test  : {X_test.index[0].date()} → {X_test.index[-1].date()} ({len(X_test)} dates)\")\n",
        "\n",
        "    return X_train, X_test, y_train, y_test"
      ]
    },
