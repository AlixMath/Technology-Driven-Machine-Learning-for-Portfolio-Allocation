        "---\n",
        "4. MODEL HELPERS\n",
        "---\n",
        "Architecture asset-specific : un modèle indépendant par actif,\n",
        "entraîné sur ses 9 features propres + 6 variables marché.\n",
        "Cette isolation réduit le bruit inter-actifs.\n",
        "\n",
        "Métriques d'évaluation prédictive :\n",
        "  RMSE             : pénalise les grandes erreurs\n",
        "  MAE              : plus robuste aux outliers\n",
        "  R²               : attendu négatif (marchés quasi-efficients)\n",
        "  Directional Acc. : MÉTRIQUE CLÉ — 50% = aléatoirebbi\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "d91hU50bA5GQ"
      },
      "outputs": [],
      "source": [
        "def get_asset_feature_columns(X_columns, asset):\n",
        "    market_features = [\n",
        "        \"market_ret_1\", \"market_ret_5\", \"market_vol_20\",\n",
        "        \"bond_proxy_ret_5\", \"gold_proxy_ret_5\", \"tech_proxy_ret_5\"\n",
        "    ]\n",
        "    asset_features = [c for c in X_columns if c.startswith(f\"{asset}_\")]\n",
        "    return asset_features + [c for c in market_features if c in X_columns]\n",
        "\n",
        "\n",
        "def fit_predict_per_asset_fast(X_train, X_test, y_train, y_test, model_type=\"rf\"):\n",
        "    preds        = pd.DataFrame(index=X_test.index)\n",
        "    metrics_list = []\n",
        "\n",
        "    for target_col in y_train.columns:\n",
        "        asset         = target_col.replace(\"_target\", \"\")\n",
        "        selected_cols = get_asset_feature_columns(X_train.columns, asset)\n",
        "\n",
        "        Xtr = X_train[selected_cols].replace([np.inf, -np.inf], np.nan).dropna()\n",
        "        ytr = y_train.loc[Xtr.index, target_col]\n",
        "\n",
        "        Xte       = X_test[selected_cols].replace([np.inf, -np.inf], np.nan)\n",
        "        valid_idx = Xte.dropna().index\n",
        "        Xte_valid = Xte.loc[valid_idx]\n",
        "\n",
        "        if len(Xtr) < 50 or len(Xte_valid) == 0:\n",
        "            preds[asset] = np.nan\n",
        "            continue\n",
        "\n",
        "        if model_type == \"linear\":\n",
        "            model      = LinearRegression()\n",
        "            model_name = \"Linear Regression\"\n",
        "        elif model_type == \"rf\":\n",
        "            model      = RandomForestRegressor(**RF_PARAMS)\n",
        "            model_name = \"Random Forest\"\n",
        "        else:\n",
        "            raise ValueError(\"model_type must be 'linear' or 'rf'.\")\n",
        "\n",
        "        model.fit(Xtr, ytr)\n",
        "\n",
        "        y_pred = pd.Series(index=X_test.index, dtype=float)\n",
        "        y_pred.loc[valid_idx] = model.predict(Xte_valid)\n",
        "        preds[asset] = y_pred\n",
        "\n",
        "        tmp = pd.concat([y_test[target_col], y_pred], axis=1).dropna()\n",
        "        tmp.columns = [\"y_true\", \"y_pred\"]\n",
        "\n",
        "        if len(tmp) >= 10:\n",
        "            rmse    = np.sqrt(mean_squared_error(tmp[\"y_true\"], tmp[\"y_pred\"]))\n",
        "            mae     = mean_absolute_error(tmp[\"y_true\"], tmp[\"y_pred\"])\n",
        "            r2      = r2_score(tmp[\"y_true\"], tmp[\"y_pred\"])\n",
        "            dir_acc = (np.sign(tmp[\"y_true\"]) == np.sign(tmp[\"y_pred\"])).mean()\n",
        "\n",
        "            metrics_list.append({\n",
        "                \"Asset\":                asset,\n",
        "                \"Model\":                model_name,\n",
        "                \"Num Features\":         len(selected_cols),\n",
        "                \"RMSE\":                 rmse,\n",
        "                \"MAE\":                  mae,\n",
        "                \"R2\":                   r2,\n",
        "                \"Directional Accuracy\": dir_acc\n",
        "            })\n",
        "\n",
        "    metrics = pd.DataFrame(metrics_list).round(4)\n",
        "    return preds, metrics"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "vFgfxgQYA5GQ"
      },
      "source": [
        "---\n",
        "5. PORTFOLIO UTILITIES\n",
        "---\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "I4aNobtJA5GQ"
      },
      "outputs": [],
      "source": [
        "def annualize_return(period_returns, periods_per_year):\n",
        "    return period_returns.mean() * periods_per_year\n",
        "\n",
        "\n",
        "def annualize_volatility(period_returns, periods_per_year):\n",
        "    return period_returns.std() * np.sqrt(periods_per_year)\n",
        "\n",
        "\n",
        "def sharpe_ratio(period_returns, rf_annual, periods_per_year):\n",
        "    ann_ret = annualize_return(period_returns, periods_per_year)\n",
        "    ann_vol = annualize_volatility(period_returns, periods_per_year)\n",
        "    if ann_vol == 0:\n",
        "        return np.nan\n",
        "    return (ann_ret - rf_annual) / ann_vol\n",
        "\n",
        "\n",
        "def max_drawdown(cumulative_returns):\n",
        "    running_max = cumulative_returns.cummax()\n",
        "    drawdown    = cumulative_returns / running_max - 1\n",
        "    return drawdown.min()\n",
        "\n",
        "\n",
        "def turnover_from_weights(weights_df):\n",
        "    if len(weights_df) < 2:\n",
        "        return np.nan\n",
        "    return weights_df.diff().abs().sum(axis=1).dropna().mean()\n",
        "\n",
        "\n",
        "def transaction_cost_from_weight_change(new_w, old_w, cost_rate):\n",
        "    return np.sum(np.abs(new_w - old_w)) * cost_rate"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "CzdmUFtDA5GR"
      },
      "source": [
        "---\n",
        "6. OPTIMIZATION\n",
        "---\n",
        "Optimisation SLSQP sous contraintes :\n",
        "  - Somme des poids = 1 (long-only fully invested)\n",
        "  - 0 <= w_i <= MAX_WEIGHT (diversification forcée)\n",
        "\n",
        "MAX_WEIGHT=5% force >= 20 actifs actifs, limitant l'impact\n",
        "d'une erreur de prévision sur un actif individuel.\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "k-SuWsO8A5GR"
      },
      "outputs": [],
      "source": [
        "def optimize_max_sharpe(expected_returns, cov_matrix, rf_annual, max_weight=0.10):\n",
        "    n_assets = len(expected_returns)\n",
        "\n",
        "    def objective(weights):\n",
        "        port_return = np.dot(weights, expected_returns)\n",
        "        port_vol    = np.sqrt(weights.T @ cov_matrix @ weights)\n",
        "        if port_vol == 0:\n",
        "            return 1e6\n",
        "        return -((port_return - rf_annual) / port_vol)\n",
        "\n",
        "    constraints = [{\"type\": \"eq\", \"fun\": lambda w: np.sum(w) - 1}]\n",
        "    bounds      = [(0, max_weight) for _ in range(n_assets)]\n",
        "    w0          = np.ones(n_assets) / n_assets\n",
        "\n",
        "    result = minimize(\n",
        "        objective,\n",
        "        w0,\n",
        "        method=\"SLSQP\",\n",
        "        bounds=bounds,\n",
        "        constraints=constraints\n",
        "    )\n",
        "\n",
        "    return result.x if result.success else w0"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "IIKOShiDA5GR"
      },
      "source": [
        "---\n",
        "7. SIGNALS\n",
        "---\n",
        "Les prévisions brutes sont transformées en rank z-score.\n",
        "\n",
        "Signal : z_i = alpha * (rank(r_hat_i) - mean) / std\n",
        "\n",
        "Deux avantages :\n",
        "  1. Robustesse aux outliers (le rang neutralise les extrêmes)\n",
        "  2. Shrinkage (alpha=0.30) : atténue le signal pour limiter\n",
        "     le turnover et éviter la sur-confiance dans des prévisions\n",
        "     bruitées (Directional Accuracy ~53%, pas 100%)\n",
        "---\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "gHkyLU_4A5GR"
      },
      "outputs": [],
      "source": [
        "def prediction_to_rank_signal(pred_series, shrinkage_alpha=0.30):\n",
        "    s = pred_series.copy().dropna()\n",
        "\n",
        "    if len(s) < 5:\n",
        "        return pd.Series(index=pred_series.index, data=0.0)\n",
        "\n",
        "    ranks = s.rank()\n",
        "    z     = (ranks - ranks.mean()) / ranks.std()\n",
        "    z     = shrinkage_alpha * z\n",
        "\n",
        "    out = pd.Series(index=pred_series.index, data=0.0)\n",
        "    out.loc[z.index] = z\n",
        "    return out"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "N7I0Sml_A5GR"
      },
      "source": [
        "---\n",
        "8. ROLLING ESTIMATORS FOR BACKTEST\n",
        "---\n",
        "Covariance et rendements espérés estimés sur fenêtre glissante\n",
        "de 40 jours, annualisés. Permet au modèle de s'adapter aux\n",
        "changements de régime sans look-ahead.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "CHdTNgqsA5GR"
      },
      "outputs": [],
      "source": [
        "def build_rolling_covariance(realized_returns, window=40, periods_per_year=252/5):\n",
        "    cov_dict = {}\n",
        "    for i in range(window, len(realized_returns)):\n",
        "        date = realized_returns.index[i]\n",
        "        cov_dict[date] = realized_returns.iloc[i-window:i].cov() * periods_per_year\n",
        "    return cov_dict\n",
        "\n",
        "\n",
        "def build_rolling_historical_mean(realized_returns, window=40, periods_per_year=252/5):\n",
        "    mean_dict = {}\n",
        "    for i in range(window, len(realized_returns)):\n",
        "        date = realized_returns.index[i]\n",
        "        mean_dict[date] = realized_returns.iloc[i-window:i].mean() * periods_per_year\n",
        "    return mean_dict"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "hsJihmDwA5GR"
      },
      "source": [
        "---\n",
        "9. FAST BACKTEST\n",
        "---\n",
        "Simulation de gestion dynamique sur la période de test.\n",
        "\n",
        "Mécanismes clés :\n",
        "  - Rebalancement tous les REBALANCE_EVERY périodes (~40j)\n",
        "  - Coûts de transaction : 10 bps × variation de poids\n",
        "  - Drift des poids entre rebalancements (économiquement correct)\n",
        "  - Itération par sauts de HORIZON_DAYS pour éviter l'overlapping\n",
        "\n",
        "4 stratégies simulées simultanément :\n",
        "  RF_MaxSharpe             : rank z-score RF → Max Sharpe\n",
        "  Linear_MaxSharpe         : rank z-score OLS → Max Sharpe\n",
        "  EqualWeight              : 1/N rebalancé périodiquement\n",
        "  Hist_Markowitz_MaxSharpe : moyennes historiques → Max Sharpe\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "j6YLYXv9A5GS"
      },
      "outputs": [],
      "source": [
        "def backtest_all_portfolios_fast(\n",
        "    realized_returns,\n",
        "    rf_predictions,\n",
        "    linear_predictions,\n",
        "    X_features,\n",
        "    rf_annual=0.02,\n",
        "    cov_window=40,\n",
        "    periods_per_year=252/5,\n",
        "    max_weight=0.10,\n",
        "    transaction_cost_rate=0.001,\n",
        "    rebalance_every=4\n",
        "):\n",
        "    common_index = (\n",
        "        realized_returns.index\n",
        "        .intersection(rf_predictions.index)\n",
        "        .intersection(linear_predictions.index)\n",
        "        .intersection(X_features.index)\n",
        "    )\n",
        "\n",
        "    realized_returns   = realized_returns.loc[common_index].copy()\n",
        "    rf_predictions     = rf_predictions.loc[common_index].copy()\n",
        "    linear_predictions = linear_predictions.loc[common_index].copy()\n",
        "    X_features         = X_features.loc[common_index].copy()\n",
        "\n",
        "    if len(common_index) <= cov_window + 5:\n",
        "        raise ValueError(\"Not enough observations for backtest.\")\n",
        "\n",
        "    cov_dict       = build_rolling_covariance(realized_returns, window=cov_window, periods_per_year=periods_per_year)\n",
        "    hist_mean_dict = build_rolling_historical_mean(realized_returns, window=cov_window, periods_per_year=periods_per_year)\n",
        "\n",
        "    tickers  = list(realized_returns.columns)\n",
        "    n_assets = len(tickers)\n",
        "\n",
        "    portfolio_rows = []\n",
        "    weight_history = {\n",
        "        \"RF_MaxSharpe\": [],\n",
        "        \"Linear_MaxSharpe\": [],\n",
        "        \"EqualWeight\": [],\n",
        "        \"Hist_Markowitz_MaxSharpe\": []\n",
        "    }\n",
        "\n",
        "    current_weights = {k: np.ones(n_assets) / n_assets for k in weight_history.keys()}\n",
        "    prev_weights    = {k: np.ones(n_assets) / n_assets for k in weight_history.keys()}\n",
        "\n",
        "    all_valid_dates = [d for d in common_index if d in cov_dict and d in hist_mean_dict]\n",
        "\n",
        "    # Itération par sauts de HORIZON_DAYS pour éviter l'overlapping\n",
        "    horizon     = max(1, round(TRADING_DAYS / periods_per_year))\n",
        "    valid_dates = all_valid_dates[::horizon]\n",
        "\n",
        "    for t, date in enumerate(valid_dates):\n",
        "        cov_matrix   = cov_dict[date].values\n",
        "        realized_vec = realized_returns.loc[date].values\n",
        "        do_rebalance = (t % rebalance_every == 0)\n",
        "\n",
        "        if do_rebalance:\n",
        "            rf_signal  = prediction_to_rank_signal(rf_predictions.loc[date],     shrinkage_alpha=SHRINKAGE_ALPHA)\n",
        "            lin_signal = prediction_to_rank_signal(linear_predictions.loc[date], shrinkage_alpha=SHRINKAGE_ALPHA)\n",
        "            mu_rf      = rf_signal.values\n",
        "            mu_lin     = lin_signal.values\n",
        "            mu_hist    = hist_mean_dict[date].values\n",
        "\n",
        "            new_weights = {\n",
        "                \"RF_MaxSharpe\":             optimize_max_sharpe(mu_rf,   cov_matrix, rf_annual=0.0,      max_weight=max_weight),\n",
        "                \"Linear_MaxSharpe\":         optimize_max_sharpe(mu_lin,  cov_matrix, rf_annual=0.0,      max_weight=max_weight),\n",
        "                \"EqualWeight\":              np.ones(n_assets) / n_assets,\n",
        "                \"Hist_Markowitz_MaxSharpe\": optimize_max_sharpe(mu_hist, cov_matrix, rf_annual=rf_annual, max_weight=max_weight)\n",
        "            }\n",
        "        else:\n",
        "            new_weights = {k: current_weights[k].copy() for k in current_weights.keys()}\n",
        "\n",
        "        row = {\"Date\": date}\n",
        "\n",
        "        for name, w in new_weights.items():\n",
        "            gross_ret = np.dot(w, realized_vec)\n",
        "\n",
        "            if do_rebalance:\n",
        "                tc = transaction_cost_from_weight_change(w, prev_weights[name], transaction_cost_rate)\n",
        "            else:\n",
        "                tc = 0.0\n",
        "\n",
        "            row[name] = gross_ret - tc\n",
        "\n",
        "            if name == \"EqualWeight\" and not do_rebalance:\n",
        "                drifted     = w * (1 + realized_vec)\n",
        "                drifted_sum = drifted.sum()\n",
        "                drifted     = drifted / drifted_sum if drifted_sum > 0 else np.ones(len(drifted)) / len(drifted)\n",
        "                weight_history[name].append(pd.Series(drifted, index=tickers, name=date))\n",
        "                current_weights[name] = drifted.copy()\n",
        "            else:\n",
        "                weight_history[name].append(pd.Series(w, index=tickers, name=date))\n",
        "                if do_rebalance:\n",
        "                    prev_weights[name] = w.copy()\n",
        "                current_weights[name] = w.copy()\n",
        "\n",
        "        portfolio_rows.append(row)\n",
        "\n",
        "    if len(portfolio_rows) == 0:\n",
        "        raise ValueError(\"Backtest produced no valid observations.\")\n",
        "\n",
        "    portfolio_returns = pd.DataFrame(portfolio_rows).set_index(\"Date\")\n",
        "    weights_dict      = {k: pd.DataFrame(v) for k, v in weight_history.items()}\n",
        "\n",
        "    return portfolio_returns, weights_dict"
      ]
    },
