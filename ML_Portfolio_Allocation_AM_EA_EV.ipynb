        "    linear_predictions=linear_predictions,\n",
        "    X_features=X_backtest,\n",
        "    rf_annual=RISK_FREE_RATE_ANNUAL,\n",
        "    cov_window=COV_WINDOW,\n",
        "    periods_per_year=PERIODS_PER_YEAR,\n",
        "    max_weight=MAX_WEIGHT,\n",
        "    transaction_cost_rate=TRANSACTION_COST_RATE,\n",
        "    rebalance_every=REBALANCE_EVERY\n",
        ")\n",
        "\n",
        "# --- 11.8 Performance et classement ---\n",
        "df_portfolio_performance = pd.DataFrame([\n",
        "    evaluate_portfolio(portfolio_returns[\"RF_MaxSharpe\"],             \"RF Max Sharpe\",                  weights_dict[\"RF_MaxSharpe\"],             PERIODS_PER_YEAR, RISK_FREE_RATE_ANNUAL),\n",
        "    evaluate_portfolio(portfolio_returns[\"Linear_MaxSharpe\"],         \"Linear Regression Max Sharpe\",   weights_dict[\"Linear_MaxSharpe\"],         PERIODS_PER_YEAR, RISK_FREE_RATE_ANNUAL),\n",
        "    evaluate_portfolio(portfolio_returns[\"EqualWeight\"],              \"Equal Weight\",                   weights_dict[\"EqualWeight\"],              PERIODS_PER_YEAR, RISK_FREE_RATE_ANNUAL),\n",
        "    evaluate_portfolio(portfolio_returns[\"Hist_Markowitz_MaxSharpe\"], \"Historical Markowitz Max Sharpe\",weights_dict[\"Hist_Markowitz_MaxSharpe\"], PERIODS_PER_YEAR, RISK_FREE_RATE_ANNUAL)\n",
        "]).round(4)\n",
        "\n",
        "df_final_ranking = df_portfolio_performance.sort_values(by=\"Sharpe Ratio\", ascending=False).reset_index(drop=True)\n",
        "\n",
        "# Poids moyens par stratégie\n",
        "df_avg_weights = pd.concat([\n",
        "    weights_dict[\"RF_MaxSharpe\"].mean().rename(\"RF_MaxSharpe\"),\n",
        "    weights_dict[\"Linear_MaxSharpe\"].mean().rename(\"Linear_MaxSharpe\"),\n",
        "    weights_dict[\"EqualWeight\"].mean().rename(\"EqualWeight\"),\n",
        "    weights_dict[\"Hist_Markowitz_MaxSharpe\"].mean().rename(\"Hist_Markowitz_MaxSharpe\")\n",
        "], axis=1).reset_index().rename(columns={\"index\": \"Asset\"}).round(4)\n",
        "\n",
        "# --- 11.9 Feature importance (exemple sur AAPL) ---\n",
        "EXAMPLE_ASSET = TICKERS[0]\n",
        "example_cols  = get_asset_feature_columns(X.columns, EXAMPLE_ASSET)\n",
        "X_ex          = X_train[example_cols].replace([np.inf, -np.inf], np.nan).dropna()\n",
        "y_ex          = y_train.loc[X_ex.index, f\"{EXAMPLE_ASSET}_target\"]\n",
        "\n",
        "rf_example_model = RandomForestRegressor(**RF_PARAMS)\n",
